# ============================================================================
# Brevus Agent Hub — variáveis de ambiente (copie para .env e preencha)
# ============================================================================

# --- Banco DEDICADO do hub (NÃO usar o DATABASE_URL de produção!) ---------
# Postgres com extensão pgvector. Em prod = plugin Postgres do Railway.
HUB_DATABASE_URL="postgresql://brevus_hub:hub123@localhost:5433/brevus_hub?schema=public"

# --- Fila / cache ----------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# --- LLM (Claude) — conta com ZDR/DPA habilitado --------------------------
ANTHROPIC_API_KEY=""
# Modelos padrão (override por agente no banco)
HUB_MODEL_DEFAULT="claude-sonnet-4-6"
HUB_MODEL_DEEP="claude-opus-4-8"

# --- Embeddings self-hosted ------------------------------------------------
# 'xenova' = roda modelo ONNX local em Node (CPU). 'ollama' = sidecar Ollama.
EMBEDDINGS_PROVIDER="xenova"
EMBEDDINGS_MODEL="Xenova/all-MiniLM-L6-v2"
# Se EMBEDDINGS_PROVIDER=ollama:
OLLAMA_URL="http://localhost:11434"
OLLAMA_EMBED_MODEL="nomic-embed-text"

# --- Auth do dashboard (single-tenant) ------------------------------------
NEXTAUTH_URL="http://localhost:3100"
NEXTAUTH_SECRET=""
# Login por credencial única do dono:
HUB_OWNER_EMAIL="vinimpm@hotmail.com"
HUB_OWNER_PASSWORD=""

# --- Segredos de integração (fail-closed) ---------------------------------
CRON_SECRET=""
# Mesmo valor configurado no web para GET /api/internal/metrics
HUB_METRICS_SECRET=""
# Base URL do web de produção (para a tool get_metrics)
BREVUS_WEB_URL="https://brevus.com.br"

# --- Repos para ingestão RAG ----------------------------------------------
# Em PROD (Railway): o worker CLONA os repos (read-only) usando GIT_TOKEN.
RAG_REPO_WEB="https://github.com/vinimpm/brevus.git"
RAG_REPO_MOBILE="https://github.com/vinimpm/brevus-mobile.git"
# Fine-grained PAT do GitHub com permissão SOMENTE de leitura (Contents: Read)
# nos dois repositórios. NUNCA com escopo de escrita.
GIT_TOKEN=""
# Onde clonar em prod (efêmero ou volume).
RAG_WORK_DIR="./data/repos"
# Em DEV: aponte para as cópias locais e o clone é ignorado (mais rápido).
RAG_LOCAL_WEB=""
RAG_LOCAL_MOBILE=""
MODELS_DIR="./.models"

# --- Entrega de relatórios -------------------------------------------------
RESEND_API_KEY=""
REPORT_EMAIL_TO="vinimpm@hotmail.com"
REPORT_EMAIL_FROM="hub@brevus.com.br"
# Endpoint do baileys-server para WhatsApp (opcional)
BAILEYS_URL=""
REPORT_WHATSAPP_TO=""
